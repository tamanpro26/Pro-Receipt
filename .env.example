# ── Frontend ──────────────────────────────────────────────────────────────────
# OpenAI API key – get at platform.openai.com/account/api-keys
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# URL where the frontend is hosted (used for CORS and self-referential links)
APP_URL="https://pro-receipt.onrender.com/"

# Backend API URL seen by the browser.
# Leave empty in production (same-origin Express server handles /api/*).
# In dev the Vite proxy forwards /api/* → localhost:3001 automatically.
VITE_API_URL=""

# ── Clerk Authentication (optional – enables chat history persistence) ────────
# Get these from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY="pk_test_ZXBpYy1zdHVkLTQ5LmNsZXJrLmFjY291bnRzLmRldiQ"
CLERK_PUBLISHABLE_KEY="pk_test_ZXBpYy1zdHVkLTQ5LmNsZXJrLmFjY291bnRzLmRldiQ"
CLERK_SECRET_KEY="sk_test_2H8sEduwJ1h0xV0HxX9KerE6U8xLoDWQukgHehZGpQ"

# ── Backend / Email (server.ts) ───────────────────────────────────────────────
# SMTP server hostname.
# Examples:
#   Gmail:    smtp.gmail.com        (use an App Password, not your real password)
#   Outlook:  smtp.office365.com
#   SendGrid: smtp.sendgrid.net
#   Mailgun:  smtp.mailgun.org
#   Any SMTP: your provider's host
SMTP_HOST="smtp.gmail.com"

# SMTP port (587 for STARTTLS, 465 for SSL, 25 for plain – 587 is recommended)
SMTP_PORT="587"

# Set to "true" only when using port 465 (SSL). Leave "false" for port 587 (STARTTLS).
SMTP_SECURE="false"

# SMTP login credentials
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password-or-app-password"

# "From" address shown in the recipient's inbox (defaults to SMTP_USER if not set)
SMTP_FROM="ProReceipt <your-email@example.com>"
